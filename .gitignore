/target
**/*.rs.bk
Cargo.lock.orig
# local client/server state produced at runtime
*.logos
/run
*.redb
.env

# generated/built iOS artifacts (produced by scripts/build-ios.sh / xcodegen)
ios/bindings/
ios/LogosKit/Sources/LogosKit/Generated/
ios/LogosKit/LogosFFI.xcframework/
ios/LogosApp/*.xcodeproj/
.build/
.swiftpm/

# generated/built web client artifacts (produced by web/build-wasm.sh)
web/public/wasm/
web/public/logos-icon.png
web/public/logos-wordmark.png
# local dev handoff notes — keep out of the public repo
web/HANDOFF.md
